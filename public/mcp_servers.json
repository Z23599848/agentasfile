{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "description": "Browser automation and inspection tools."
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "Safe access to the local filesystem."
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "description": "Manage repositories, issues, and PRs."
    },
    "whisper": {
      "command": "npx",
      "args": ["-y", "fast-whisper-mcp-server"],
      "description": "High-performance local speech-to-text."
    },
    "gemma": {
      "command": "npx",
      "args": ["-y", "ollama-mcp-server"],
      "description": "Connect to local Gemma models via Ollama."
    }
  }
}
